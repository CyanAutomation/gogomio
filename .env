# GoGoMio Environment Configuration

# ------------------------------------------------------------
# Service Configuration
# ------------------------------------------------------------

# GoGoMio image tag - can be pinned to specific version like "v0.1.0"
GOGOMIO_IMAGE_TAG=latest

# HTTP server port - 8000 is default but can be changed if needed
GOGOMIO_PORT=8000

# Camera Resolution (default: 640x480, common alternatives: 1280x720, 1920x1080)
MIO_RESOLUTION=640x480

# Camera frames per second (default: 24, typical range: 15-30)
MIO_FPS=24

# Target FPS for encoding - helps throttle CPU usage (default: same as FPS)
MIO_TARGET_FPS=24

# JPEG compression quality 1-100 (default: 90, higher = better quality but larger files)
MIO_JPEG_QUALITY=90

# Maximum concurrent stream connections (default: 10)
MIO_MAX_STREAM_CONNECTIONS=2

# Server bind address (0.0.0.0 = listen on all interfaces)
MIO_BIND_HOST=0.0.0.0

# Application mode: "webcam" for camera streaming or "management" for hub mode
MIO_APP_MODE=webcam

# Mock camera mode for testing without hardware (true/false)
MOCK_CAMERA=false

# ------------------------------------------------------------
# Global Settings
# ------------------------------------------------------------

# Timezone
TZ=Europe/London

# User and Group IDs (for file permissions in volumes)
PUID=1000
PGID=1000