# GoGoMio environment configuration example.
# Copy to .env and customize values:
#   cp .env.example .env

# Camera mode toggle for local/dev usage (MOCK_CAMERA=true skips hardware camera access).
MOCK_CAMERA=false # accepted: true|false|1|0

# Capture resolution in WIDTHxHEIGHT format.
MIO_RESOLUTION=640x480 # format: <positive-int>x<positive-int> (example: 1280x720)

# Camera capture frame rate.
MIO_FPS=24 # range: integer > 0

# Internal target processing frame rate; defaults to MIO_FPS when unset.
MIO_TARGET_FPS=24 # range: integer > 0

# JPEG encoder quality.
MIO_JPEG_QUALITY=90 # range: 1-100 (higher = better quality, larger frames)

# Maximum number of concurrent MJPEG streaming clients.
MIO_MAX_STREAM_CONNECTIONS=2 # range: integer > 0

# App bind address and port (used by local runs and container server internals).
MIO_BIND_HOST=0.0.0.0 # accepted: IPv4/IPv6/hostname
MIO_PORT=8000 # range: 1-65535

# Host port published by docker-compose (maps host->container port).
GOGOMIO_PORT=8000 # range: 1-65535; keep equal to MIO_PORT for 1:1 mapping

# Optional timezone for container logs/runtime behavior.
TZ=UTC # accepted: IANA timezone (example: UTC, America/Los_Angeles)
